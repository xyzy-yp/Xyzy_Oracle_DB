create or replace function cdb_substrf(p_string in varchar2,p_symbol in varchar2,p_num in number) return varchar2 is
  l_string varchar2(2000);
  l_symbol_position1 number;
  l_symbol_position2 number;
  l_lengthb number;
  l_num     number;
begin
  --des:取字符串中指定符号后面的几段，如 cdb_substrf('10.0.1232001.0.0.1001.0','.',1) ;
  --p_string 字符串; p_symbol 符号 ; p_num 第几个（-5.-4.-3.-2-.1.1.2.3）
  --字符长度只支持2000个字节
  --init
  l_string  := '';
  l_num     := p_num;
  l_lengthb := lengthb(p_string);
  --a.1 get l_num
  if(p_num < 0) then
   l_num := regexp_count(p_string,'-')+2+p_num;
  end if;
  --1.0 不能小于0
  if(l_num < 1) then
    goto end_do;
  end if;
  --1.0 get symbol position1
  if(l_num = 1) then
    l_symbol_position1 := 0;
  else
    l_symbol_position1 := instrb(p_string,p_symbol,1,l_num-1);
  end if;
  if(l_symbol_position1 = 0 and l_num <> 1) then
    goto end_do;
  end if;
  --2.0 get symbol position2
  l_symbol_position2 := instrb(p_string,p_symbol,1,l_num);
  if(l_symbol_position2 = 0) then
    l_symbol_position2 := l_lengthb+1;
  end if;
  --3.0 get behind string
  if(1 = 1) then
    l_string := substrb(p_string,l_symbol_position1+1,l_symbol_position2-l_symbol_position1-1);
  end if;
  ----------------------------------
  <<end_do>>
  null;
  return l_string;
exception
  when others then
       return '';
end cdb_substrf;
